# MongoDB Connection String (отримаєш в MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@mblog.rsvvh2g.mongodb.net/MarketingBlog?retryWrites=true&w=majority

# Port for the server
PORT=5000

# Secret key for JWT (придумай довгий випадковий набір символів)
JWT_SECRET=your_super_secret_jwt_key_here

# Admin credentials
ADMIN_USERNAME=your_admin_email@example.com
ADMIN_PASSWORD=your_admin_password

# Cloudinary configuration (отримаєш в консолі Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here